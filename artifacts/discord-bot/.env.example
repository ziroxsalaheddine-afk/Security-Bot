# ── Required ──────────────────────────────────────────────────────────────────
# Your Discord bot token — generate/reset at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── Optional: self-hosted Lavalink node (music) ───────────────────────────────
# If set, this node is used as the primary music source before the public fallbacks.
# Format: https://host:port
LAVALINK_URI=
LAVALINK_PASSWORD=
